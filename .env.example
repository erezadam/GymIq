# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin credentials — used by maintenance/migration scripts and the
# auto-draft-release-note workflow to sign in as an admin user. Not related to
# any test framework. (Previously named E2E_ADMIN_*; the prefix was misleading.)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
