rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /trainee-photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /exercise-sets/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
